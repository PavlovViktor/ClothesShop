<Page x:Class="Command_3_Project.Pages.AuthPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Command_3_Project.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AuthPage">

    <Grid>
        <StackPanel Width="250" Height="115" Orientation="Vertical">
            <StackPanel Margin="2" Orientation="Horizontal">
                <TextBlock Width="100" Text="Введите логин: " TextAlignment="Right"/>
                <TextBox  Width="145.9" x:Name="LoginSpot"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="2">
                <TextBlock Width="100" Text="Введите пароль: " TextAlignment="Right" />
                <TextBox  Width="145.9" x:Name="PasswordSpot"/>
            </StackPanel>
            <Button x:Name="EnterBtn" Click="EnterBtn_Click" Content="Войти" Margin="2"></Button>
            <Button x:Name="RegisterBtn" Click="RegisterBtn_Click" Content="Регистрация" Margin="2,15,2,2"></Button>
        </StackPanel>
        
    </Grid>
</Page>
